    <diagram name="Orbit Rotation Sequence" id="orbit_seq">
        <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>

                <!-- Title -->
                <mxCell id="title" value="Sequence: Orbit Rotation Drag (OrbitalCameraManipulator + EulerOrbitStrategy)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="100" y="10" width="900" height="30" as="geometry"/>
                </mxCell>

                <!-- Lifelines -->
                <mxCell id="ll_app" value="App / GLFW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1565c0;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="60" y="60" width="120" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="ll_ctrl" value="Inspect3DController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="260" y="60" width="160" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="ll_mapper" value="InputMapper" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="500" y="60" width="120" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="ll_manip" value="OrbitalCamera&#10;Manipulator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f57f17;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="700" y="55" width="140" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="ll_strat" value="EulerOrbitStrategy&#10;(IRotationStrategy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#6a1b9a;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="920" y="55" width="160" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="ll_cam" value="ICamera" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1160" y="60" width="100" height="40" as="geometry"/>
                </mxCell>

                <!-- Lifeline lines -->
                <mxCell id="lv_app" style="endArrow=none;html=1;strokeColor=#1565c0;strokeWidth=1;dashed=1;" parent="1" source="ll_app" target="ll_app" edge="1">
                    <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="120" y="800"/></Array></mxGeometry>
                </mxCell>

                <!-- Step 1: MouseButtonPressed -->
                <mxCell id="s1" value="MouseButtonPressed(btn=right, x=640, y=360)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#1565c0;" parent="1" source="ll_app" target="ll_ctrl" edge="1">
                    <mxGeometry y="40" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s1l" value="" style="edgeLabel;html=1;align=center;verticalAlign=top;resizable=0;points=[];fontSize=10;" parent="s1" connectable="0" vertex="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- Step 2: onEvent -> mapper.onMouseButton -->
                <mxCell id="s2" value="onEvent(MouseButtonPressedEvent, dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#2e7d32;" parent="1" source="ll_ctrl" target="ll_mapper" edge="1">
                    <mxGeometry y="60" relative="1" as="geometry"/>
                </mxCell>

                <!-- Step 3: eBeginRotate callback -->
                <mxCell id="s3" value="callback(eBeginRotate, {x=640,y=360}, dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#e65100;" parent="1" source="ll_mapper" target="ll_manip" edge="1">
                    <mxGeometry y="90" relative="1" as="geometry"/>
                </mxCell>

                <!-- Step 4: beginRotate -> strategy -->
                <mxCell id="s4" value="beginRotate(640,360)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#f57f17;" parent="1" source="ll_manip" target="ll_strat" edge="1">
                    <mxGeometry y="120" relative="1" as="geometry"/>
                </mxCell>

                <!-- Step 5: syncFromCamera -->
                <mxCell id="s5" value="syncFromCamera(ctx)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#6a1b9a;" parent="1" source="ll_strat" target="ll_cam" edge="1">
                    <mxGeometry y="150" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s5r" value="position, target, up" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1;strokeColor=#6a1b9a;dashed=1;" parent="1" source="ll_cam" target="ll_strat" edge="1">
                    <mxGeometry y="170" relative="1" as="geometry"/>
                </mxCell>

                <!-- Separator: Mouse move events -->
                <mxCell id="sep1" value="[loop: each mousemove event]" style="text;html=1;strokeColor=#aaaaaa;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="60" y="310" width="1200" height="25" as="geometry"/>
                </mxCell>

                <!-- Step 6: MouseMoved -->
                <mxCell id="s6" value="MouseMoved(x=650, y=370)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#1565c0;" parent="1" source="ll_app" target="ll_ctrl" edge="1">
                    <mxGeometry y="240" relative="1" as="geometry"/>
                </mxCell>

                <!-- Step 7: mapper.onMouseMove -->
                <mxCell id="s7" value="onEvent(MouseMovedEvent)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#2e7d32;" parent="1" source="ll_ctrl" target="ll_mapper" edge="1">
                    <mxGeometry y="260" relative="1" as="geometry"/>
                </mxCell>

                <!-- Step 8: eRotateDelta -->
                <mxCell id="s8" value="callback(eRotateDelta, {x=650,y=370,dx=10,dy=10}, dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#e65100;" parent="1" source="ll_mapper" target="ll_manip" edge="1">
                    <mxGeometry y="290" relative="1" as="geometry"/>
                </mxCell>

                <!-- Step 9: dragRotate -> strategy -->
                <mxCell id="s9" value="dragRotate(650,370,10,10,dt,ctx)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#f57f17;" parent="1" source="ll_manip" target="ll_strat" edge="1">
                    <mxGeometry y="320" relative="1" as="geometry"/>
                </mxCell>

                <!-- Step 10: orbit.applyDrag -->
                <mxCell id="s10" value="orbit_.applyDrag(dx,dy,speed,dt,minDt)&#10;→ yaw += dx*speed, pitch -= dy*speed" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#6a1b9a;" parent="1" vertex="1">
                    <mxGeometry x="940" y="430" width="280" height="40" as="geometry"/>
                </mxCell>

                <!-- Step 11: applyToCamera -->
                <mxCell id="s11" value="applyToCamera() → computeBackDir() → lookAt(eye, coi, up)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#f57f17;" parent="1" source="ll_manip" target="ll_cam" edge="1">
                    <mxGeometry y="380" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s11r" value="updateMatrices()" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1;strokeColor=#2e7d32;dashed=1;" parent="1" source="ll_cam" target="ll_manip" edge="1">
                    <mxGeometry y="400" relative="1" as="geometry"/>
                </mxCell>

                <!-- Separator: mouse release -->
                <mxCell id="sep2" value="[mouse button released]" style="text;html=1;strokeColor=#aaaaaa;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="60" y="570" width="1200" height="25" as="geometry"/>
                </mxCell>

                <!-- Step 12: eEndRotate -->
                <mxCell id="s12" value="callback(eEndRotate, payload, dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#e65100;" parent="1" source="ll_mapper" target="ll_manip" edge="1">
                    <mxGeometry y="500" relative="1" as="geometry"/>
                </mxCell>

                <!-- Step 13: endRotate -> strategy captures inertia -->
                <mxCell id="s13" value="endRotate(inertia_enabled, dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#f57f17;" parent="1" source="ll_manip" target="ll_strat" edge="1">
                    <mxGeometry y="530" relative="1" as="geometry"/>
                </mxCell>

                <!-- Step 14: onUpdate inertia -->
                <mxCell id="sep3" value="[each frame while coasting]" style="text;html=1;strokeColor=#aaaaaa;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="60" y="700" width="1200" height="25" as="geometry"/>
                </mxCell>

                <mxCell id="s14" value="onUpdate(dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#2e7d32;" parent="1" source="ll_ctrl" target="ll_manip" edge="1">
                    <mxGeometry y="620" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s15" value="applyInertia(dt) → strategy.stepInertia(dt, damping, ctx)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#f57f17;" parent="1" source="ll_manip" target="ll_strat" edge="1">
                    <mxGeometry y="650" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s16" value="applyToCamera()" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#f57f17;" parent="1" source="ll_manip" target="ll_cam" edge="1">
                    <mxGeometry y="680" relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram name="FPS Movement Sequence" id="fps_seq">
        <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>

                <!-- Title -->
                <mxCell id="title2" value="Sequence: FPS Camera Movement (Navigation3DController)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontStyle=1;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="100" y="10" width="900" height="30" as="geometry"/>
                </mxCell>

                <!-- Lifelines -->
                <mxCell id="ll2_app" value="App / GLFW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1565c0;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="60" y="60" width="120" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="ll2_nav" value="Navigation3DController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="250" y="60" width="180" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="ll2_mapper" value="InputMapper" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="510" y="60" width="120" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="ll2_rig" value="CameraRig" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="720" y="60" width="120" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="ll2_fl" value="FreeLookManipulator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f57f17;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="920" y="60" width="180" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="ll2_cam" value="ICamera" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontStyle=1;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1190" y="60" width="100" height="40" as="geometry"/>
                </mxCell>

                <!-- Key Down: W -->
                <mxCell id="t1" value="KeyPressed(W)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#1565c0;" parent="1" source="ll2_app" target="ll2_nav" edge="1">
                    <mxGeometry y="50" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t2" value="onEvent(KeyEvent, dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#2e7d32;" parent="1" source="ll2_nav" target="ll2_mapper" edge="1">
                    <mxGeometry y="70" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t3" value="mapper.onKey(W=87, pressed=true, dt)" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#e65100;" parent="1" vertex="1">
                    <mxGeometry x="510" y="165" width="340" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="t4" value="callback(eMoveForward, {pressed=true}, dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#e65100;" parent="1" source="ll2_mapper" target="ll2_rig" edge="1">
                    <mxGeometry y="130" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t5" value="rig.onAction(eMoveForward, payload, dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#2e7d32;" parent="1" source="ll2_rig" target="ll2_fl" edge="1">
                    <mxGeometry y="160" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t6" value="move_forward_held_ = true" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#f57f17;" parent="1" vertex="1">
                    <mxGeometry x="920" y="260" width="260" height="25" as="geometry"/>
                </mxCell>

                <!-- Frame loop -->
                <mxCell id="sep_f" value="[each frame while W held — onUpdate(dt)]" style="text;html=1;strokeColor=#aaaaaa;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="60" y="330" width="1230" height="25" as="geometry"/>
                </mxCell>

                <mxCell id="t7" value="onUpdate(dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#2e7d32;" parent="1" source="ll2_nav" target="ll2_rig" edge="1">
                    <mxGeometry y="280" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t8" value="rig.onUpdate(dt) → freeLook.onUpdate(dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#2e7d32;" parent="1" source="ll2_rig" target="ll2_fl" edge="1">
                    <mxGeometry y="310" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t9" value="front = computeFront()&#10;eye += front * speed * sprint * dt" style="endArrow=none;html=1;strokeWidth=1;strokeColor=#f57f17;" parent="1" vertex="1">
                    <mxGeometry x="920" y="435" width="260" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="t10" value="camera.setPosition(new_eye)&#10;camera.updateMatrices()" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#f57f17;" parent="1" source="ll2_fl" target="ll2_cam" edge="1">
                    <mxGeometry y="380" relative="1" as="geometry"/>
                </mxCell>

                <!-- Mouse look -->
                <mxCell id="sep_look" value="[right mouse button held + mouse move → eLookDelta]" style="text;html=1;strokeColor=#aaaaaa;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="60" y="540" width="1230" height="25" as="geometry"/>
                </mxCell>

                <mxCell id="t11" value="callback(eLookDelta, {dx,dy}, dt)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#e65100;" parent="1" source="ll2_mapper" target="ll2_rig" edge="1">
                    <mxGeometry y="470" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t12" value="freeLook.onAction(eLookDelta, ...)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#2e7d32;" parent="1" source="ll2_rig" target="ll2_fl" edge="1">
                    <mxGeometry y="500" relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="t13" value="yaw += dx * sensitivity&#10;pitch = clamp(pitch - dy * sens, -89, 89)&#10;→ camera.lookAt(eye, eye+front, world_up)" style="endArrow=blockThin;endFill=1;html=1;strokeWidth=1.5;strokeColor=#f57f17;" parent="1" source="ll2_fl" target="ll2_cam" edge="1">
                    <mxGeometry y="550" relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
